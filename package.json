{
  "name": "iptv-web-os",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint \"assets/js/**/*.js\" \"tests/**/*.js\"",
    "format": "prettier --write \"**/*.{js,css,html,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,css,html,json,md,yml,yaml}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "eslint": "^9.22.0",
    "prettier": "^3.3.3",
    "vitest": "^2.1.8"
  }
}
